{{ 'kracht-announcement-bar.css' | asset_url | stylesheet_tag }}

<div
  class="kracht-announcement-bar"
  style="
    --kab-bg: {{ section.settings.background_color }};
    --kab-fg: {{ section.settings.text_color }};
    --kab-pad-y: {{ section.settings.padding_y }}px;
    --kab-font-size: {{ section.settings.font_size }}px;
  "
>
  <div class="kracht-announcement-bar__track" data-speed="{{ section.settings.scroll_speed }}">
    {% for block in section.blocks %}
      {%- assign repeats = section.settings.repeat_count | default: 4 -%}
      {%- for i in (1..repeats) -%}
        {%- if block.settings.link != blank -%}
          <a class="kracht-announcement-bar__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </a>
        {%- else -%}
          <span class="kracht-announcement-bar__item" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </span>
        {%- endif -%}
        <span class="kracht-announcement-bar__sep" aria-hidden="true">·</span>
      {%- endfor -%}
    {% endfor %}
  </div>

  {% if section.settings.show_dashed_border %}
    <div class="kracht-announcement-bar__dashed" aria-hidden="true"></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Kracht — Announcement Bar",
  "tag": "section",
  "class": "kracht-announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#009de1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "checkbox",
      "id": "show_dashed_border",
      "label": "Show dashed bottom border",
      "default": true
    },
    {
      "type": "header",
      "content": "Scrolling"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed (seconds per loop)",
      "min": 0,
      "max": 60,
      "step": 5,
      "default": 0,
      "info": "Set to 0 to disable scrolling (centered static)."
    },
    {
      "type": "range",
      "id": "repeat_count",
      "label": "Repeat each message",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4,
      "info": "Only matters if scrolling is on."
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Gratis verzending bij bestellingen boven €50"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Announcement Bar",
      "settings": {
        "background_color": "#009de1",
        "text_color": "#ffffff"
      },
      "blocks": [
        { "type": "message", "settings": { "text": "Gratis verzending bij bestellingen boven €50" } },
        { "type": "message", "settings": { "text": "Werken vanuit Kracht!" } }
      ]
    }
  ]
}
{% endschema %}
