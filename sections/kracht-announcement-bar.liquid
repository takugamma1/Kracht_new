{{ 'kracht-announcement-bar.css' | asset_url | stylesheet_tag }}

<div
  class="kracht-announcement-bar{% if request.design_mode %} kracht-announcement-bar--static{% endif %}"
  style="
    --kab-bg: {{ section.settings.background_color }};
    --kab-fg: {{ section.settings.text_color }};
    --kab-pad-y: {{ section.settings.padding_y }}px;
    --kab-font-size: {{ section.settings.font_size }}px;
    --kab-speed: {{ section.settings.scroll_speed | default: 30 }}s;
  "
>
  <div class="kracht-announcement-bar__track">
    {%- comment -%}
      Ten identical groups; the CSS loop shifts exactly one group (-10%), so
      the animation is seamless AND the track always out-spans wide viewports
      (two copies of a short message left a visible gap sweeping through).
      Clones are aria-hidden and carry no editor attributes.
    {%- endcomment -%}
    {%- for copy in (1..10) -%}
      {%- assign is_real = forloop.first -%}
      <div class="kracht-announcement-bar__group"{% unless is_real %} aria-hidden="true"{% endunless %}>
        {%- for block in section.blocks -%}
          {%- if block.settings.link != blank -%}
            <a class="kracht-announcement-bar__item" href="{{ block.settings.link }}"{% if is_real %} {{ block.shopify_attributes }}{% endif %}>{{ block.settings.text }}</a>
          {%- else -%}
            <span class="kracht-announcement-bar__item"{% if is_real %} {{ block.shopify_attributes }}{% endif %}>{{ block.settings.text }}</span>
          {%- endif -%}
          <span class="kracht-announcement-bar__sep" aria-hidden="true">·</span>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>

  {% if section.settings.show_dashed_border %}
    <div class="kracht-announcement-bar__dashed" aria-hidden="true"></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Kracht — Announcement Bar",
  "tag": "section",
  "class": "kracht-announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#009de1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 11,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Marquee speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_dashed_border",
      "label": "Show dashed bottom border",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Gratis verzending bij bestellingen boven €50"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Announcement Bar",
      "settings": {
        "background_color": "#009de1",
        "text_color": "#ffffff"
      },
      "blocks": [
        { "type": "message", "settings": { "text": "Gratis verzending bij bestellingen boven €50" } },
        { "type": "message", "settings": { "text": "Werken vanuit Kracht!" } }
      ]
    }
  ]
}
{% endschema %}
