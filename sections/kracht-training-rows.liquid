{{ 'kracht-training-rows.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-trrows"
  style="
    --ktr-bg: {{ section.settings.background_color }};
    --ktr-fg: {{ section.settings.text_color }};
    --ktr-card-bg: {{ section.settings.card_color }};
    --ktr-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --ktr-radius: {{ section.settings.radius }}px;
  "
>
  <div class="kracht-trrows__inner kracht-container">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.intro != blank -%}
      <div class="kracht-trrows__head">
        <div class="kracht-trrows__head-left">
          {%- if section.settings.eyebrow != blank -%}
            <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="kracht-trrows__title">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="kracht-trrows__intro">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kracht-trrows__list">
      {%- for block in section.blocks -%}
        {%- assign mod = forloop.index | modulo: 2 -%}
        {%- assign reverse = false -%}
        {%- if mod == 0 -%}{%- assign reverse = true -%}{%- endif -%}

        <article class="kracht-trrow {% if reverse %}kracht-trrow--reverse{% endif %}" {{ block.shopify_attributes }}>
          <div class="kracht-trrow__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1000 }}"
                srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 1000 }} 1000w"
                sizes="(max-width: 900px) 100vw, 50vw"
                alt="{{ block.settings.image.alt | escape }}"
                class="kracht-trrow__img"
                loading="lazy"
              >
            {%- else -%}
              <div class="kracht-trrow__img kracht-trrow__img--ph"></div>
            {%- endif -%}

            {%- if block.settings.tag != blank -%}
              <span class="kracht-tag kracht-tag--with-plus kracht-trrow__tag">{{ block.settings.tag }}</span>
            {%- endif -%}
          </div>

          <div class="kracht-trrow__body">
            {%- if block.settings.eyebrow != blank -%}
              <span class="kracht-eyebrow kracht-trrow__eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="kracht-trrow__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <p class="kracht-trrow__desc">{{ block.settings.description }}</p>
            {%- endif -%}

            {%- if block.settings.meta1_value != blank or block.settings.meta2_value != blank or block.settings.meta3_value != blank -%}
              <div class="kracht-trrow__meta">
                {%- if block.settings.meta1_value != blank -%}
                  <span class="kracht-trrow__meta-item"{% if block.settings.meta1_label != blank %} title="{{ block.settings.meta1_label | escape }}"{% endif %}>
                    {%- if block.settings.meta1_icon != blank and block.settings.meta1_icon != 'none' -%}<span class="kracht-trrow__meta-icon">{% render 'kracht-hero-icon', icon: block.settings.meta1_icon %}</span>{%- endif -%}
                    <span>{{ block.settings.meta1_value }}</span>
                  </span>
                {%- endif -%}
                {%- if block.settings.meta2_value != blank -%}
                  <span class="kracht-trrow__meta-item"{% if block.settings.meta2_label != blank %} title="{{ block.settings.meta2_label | escape }}"{% endif %}>
                    {%- if block.settings.meta2_icon != blank and block.settings.meta2_icon != 'none' -%}<span class="kracht-trrow__meta-icon">{% render 'kracht-hero-icon', icon: block.settings.meta2_icon %}</span>{%- endif -%}
                    <span>{{ block.settings.meta2_value }}</span>
                  </span>
                {%- endif -%}
                {%- if block.settings.meta3_value != blank -%}
                  <span class="kracht-trrow__meta-item"{% if block.settings.meta3_label != blank %} title="{{ block.settings.meta3_label | escape }}"{% endif %}>
                    {%- if block.settings.meta3_icon != blank and block.settings.meta3_icon != 'none' -%}<span class="kracht-trrow__meta-icon">{% render 'kracht-hero-icon', icon: block.settings.meta3_icon %}</span>{%- endif -%}
                    <span>{{ block.settings.meta3_value }}</span>
                  </span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if block.settings.button1_label != blank or block.settings.button2_label != blank -%}
              <div class="kracht-trrow__cta">
                {%- if block.settings.button1_label != blank -%}
                  <a href="{{ block.settings.button1_link | default: '#' }}" class="kracht-btn kracht-btn--primary">
                    {{ block.settings.button1_label }} <span class="kracht-btn__arrow">→</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.button2_label != blank -%}
                  <a href="{{ block.settings.button2_link | default: '#' }}" class="kracht-trrow__link">
                    {{ block.settings.button2_label }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Training Rows",
  "tag": "section",
  "class": "kracht-trrows-section",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Section header" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow", "default": "Onze trainingen" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Drie programma's,<br><strong>één missie: <em>groei.</em></strong></p>", "info": "Use <strong> or <em> for bold emphasis (same color — headings stay single-color)." },
    { "type": "richtext", "id": "intro",   "label": "Intro paragraph", "default": "<p>Elke training is op maat te maken voor jouw team of organisatie. Klassikaal, online of hybride — altijd persoonlijk, altijd praktisch.</p>" },

    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color",       "label": "Text color",       "default": "#000000" },
    { "type": "color", "id": "card_color",       "label": "Card background",  "default": "#F8F8F8" },
    { "type": "range", "id": "padding_y",        "label": "Vertical padding", "min": 24, "max": 160, "step": 4, "unit": "px", "default": 140 },
    { "type": "range", "id": "radius",           "label": "Card corner radius", "min": 0, "max": 32, "step": 1, "unit": "px", "default": 10 }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Training",
      "settings": [
        { "type": "image_picker", "id": "image",       "label": "Image" },
        { "type": "text",         "id": "tag",         "label": "Tag (e.g. 01)", "default": "01" },
        { "type": "text",         "id": "eyebrow",     "label": "Eyebrow (e.g. 2.1.1 — Teamontwikkeling)", "default": "2.1.1 — Teamontwikkeling" },
        { "type": "text",         "id": "title",       "label": "Title", "default": "Samenwerken vanuit Kracht." },
        { "type": "textarea",     "id": "description", "label": "Description", "default": "Bouw een team dat écht samenwerkt. Van vertrouwen tot gedeelde verantwoordelijkheid — krachtiger als groep dan als optelsom van individuen." },
        { "type": "header", "content": "Metadata (icon + value)", "info": "Bold value with a blue icon; the label shows as a tooltip." },
        { "type": "text", "id": "meta1_label", "label": "Label 1 (tooltip)", "default": "Duur" },
        { "type": "text", "id": "meta1_value", "label": "Value 1", "default": "2 dagen" },
        { "type": "select", "id": "meta1_icon", "label": "Icon 1", "default": "clock", "options": [
          { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
        { "type": "text", "id": "meta2_label", "label": "Label 2 (tooltip)", "default": "Format" },
        { "type": "text", "id": "meta2_value", "label": "Value 2", "default": "Klassikaal" },
        { "type": "select", "id": "meta2_icon", "label": "Icon 2", "default": "briefcase", "options": [
          { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
        { "type": "text", "id": "meta3_label", "label": "Label 3 (tooltip)", "default": "Voor" },
        { "type": "text", "id": "meta3_value", "label": "Value 3", "default": "Teams 6 — 15 pers." },
        { "type": "select", "id": "meta3_icon", "label": "Icon 3", "default": "users", "options": [
          { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
        { "type": "header", "content": "Buttons" },
        { "type": "text", "id": "button1_label", "label": "Primary button label", "default": "Meer informatie" },
        { "type": "url",  "id": "button1_link",  "label": "Primary button link" },
        { "type": "text", "id": "button2_label", "label": "Secondary link label", "default": "Download brochure" },
        { "type": "url",  "id": "button2_link",  "label": "Secondary link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Training Rows",
      "blocks": [
        { "type": "row" },
        { "type": "row", "settings": { "tag": "02", "eyebrow": "2.1.2 — Leiderschap", "title": "Leiden vanuit Kracht.", "description": "Ontwikkel een authentieke leiderschapsstijl die past bij jou én bij je team.", "meta1_value": "4 dagdelen", "meta2_value": "Hybride", "meta3_value": "Managers & leads" } },
        { "type": "row", "settings": { "tag": "03", "eyebrow": "2.1.3 — Communicatie", "title": "Heldere taal, scherpe boodschap.", "description": "Leer écht luisteren, helder overtuigen en feedback geven die bijdraagt aan groei.", "meta1_value": "1 dag intensief", "meta2_value": "Klassikaal of online", "meta3_value": "Iedere professional" } }
      ]
    }
  ]
}
{% endschema %}
