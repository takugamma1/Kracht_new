{{ 'kracht-photo-gallery.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-pgal"
  style="
    --kpg2-bg: {{ section.settings.background_color }};
    --kpg2-fg: {{ section.settings.text_color }};
    --kpg2-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --kpg2-radius: {{ section.settings.radius }}px;
    --kpg2-gap: {{ section.settings.gap }}px;
  "
>
  <div class="kracht-pgal__inner kracht-container">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="kracht-pgal__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-pgal__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Reference mosaic: blocks 1-4 form the 2x2 left grid, block 5 is the tall right feature (position-based, no size pickers). {%- endcomment -%}
    <div class="kracht-pgal__grid">
      {%- for block in section.blocks -%}
        <figure class="kracht-pgal__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1400 }}"
              srcset="{{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 1400 }} 1400w"
              sizes="(max-width: 900px) 100vw, 50vw"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="kracht-pgal__placeholder"></div>
          {%- endif -%}
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Photo Gallery",
  "tag": "section",
  "class": "kracht-pgal-section",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Section header (optional)" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Finca Las Encinas — <strong>een plek die vertraagt.</strong></p>" },

    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#ffffff" },
    { "type": "color", "id": "text_color",       "label": "Text color",       "default": "#000000" },
    { "type": "range", "id": "padding_y",        "label": "Vertical padding", "min": 24, "max": 160, "step": 4, "unit": "px", "default": 140 },
    { "type": "range", "id": "radius",           "label": "Image radius",     "min": 0, "max": 32, "step": 1, "unit": "px", "default": 10 },
    { "type": "range", "id": "gap",              "label": "Gap between photos", "min": 4, "max": 32, "step": 2, "unit": "px", "default": 10 }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Photo Gallery",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
