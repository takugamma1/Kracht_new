{{ 'kracht-process-stepper.css' | asset_url | stylesheet_tag }}

{%- assign active_index = section.settings.active_step -%}
{%- if active_index < 1 -%}{%- assign active_index = 1 -%}{%- endif -%}

<section
  class="kracht-pstep"
  style="
    --kps-bg: {{ section.settings.background_color }};
    --kps-fg: {{ section.settings.text_color }};
    --kps-card-bg: {{ section.settings.card_color }};
    --kps-card-fg: {{ section.settings.card_text_color }};
    --kps-pad-y: {{ section.settings.padding_y }}px;
    --kps-radius: {{ section.settings.card_radius }}px;
  "
>
  <div class="kracht-pstep__inner kracht-container">
    <div class="kracht-pstep__grid">
      <div class="kracht-pstep__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-pstep__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <div class="kracht-pstep__intro">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>

      <div class="kracht-pstep__card">
        <div class="kracht-pstep__plus" aria-hidden="true">{% render 'kracht-plus' %}</div>

        <div class="kracht-pstep__rail" role="list">
          {%- for block in section.blocks -%}
            {%- assign is_active = false -%}
            {%- if forloop.index == active_index -%}{%- assign is_active = true -%}{%- endif -%}
            <span
              class="kracht-pstep__dot {% if is_active %}is-active{% endif %}"
              role="listitem"
              aria-current="{% if is_active %}step{% else %}false{% endif %}"
            ></span>
          {%- endfor -%}
          <span class="kracht-pstep__rail-line" aria-hidden="true"></span>
        </div>

        <ol class="kracht-pstep__labels">
          {%- for block in section.blocks -%}
            {%- assign is_active = false -%}
            {%- if forloop.index == active_index -%}{%- assign is_active = true -%}{%- endif -%}
            {%- assign num = forloop.index | prepend: '0' | slice: -2, 2 -%}
            <li class="kracht-pstep__label {% if is_active %}is-active{% endif %}" {{ block.shopify_attributes }}>
              <span class="kracht-pstep__label-num">{{ num }}</span>
              <span class="kracht-pstep__label-text">{{ block.settings.title }}</span>
            </li>
          {%- endfor -%}
        </ol>

        {%- assign active_block = section.blocks[active_index | minus: 1] -%}
        {%- if active_block -%}
          <div class="kracht-pstep__active">
            {%- assign active_num = active_index | prepend: '0' | slice: -2, 2 -%}
            <span class="kracht-pstep__active-eyebrow">
              Stap {{ active_num }} · {{ active_block.settings.title | upcase }}
            </span>
            {%- if active_block.settings.content_title != blank -%}
              <h3 class="kracht-pstep__active-title">{{ active_block.settings.content_title }}</h3>
            {%- endif -%}
            {%- if active_block.settings.content != blank -%}
              <div class="kracht-pstep__active-body">{{ active_block.settings.content }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Process Stepper",
  "tag": "section",
  "class": "kracht-pstep-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>In 4 stappen naar een <strong>retraite die past.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "<p>Van eerste gesprek tot terugkomst — zo werkt het bij ons. Een <strong>gestructureerd traject</strong> dat zorgt dat de retraite niet eindigt op de laatste dag.</p>"
    },
    {
      "type": "range",
      "id": "active_step",
      "label": "Active step (1-based)",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card background",
      "default": "#009de1"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "title", "label": "Step title", "default": "Stap" },
        { "type": "text", "id": "content_title", "label": "Active content title", "default": "" },
        { "type": "richtext", "id": "content", "label": "Active content body", "default": "" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Process Stepper",
      "blocks": [
        { "type": "step", "settings": { "title": "Kennismaking", "content_title": "Vrijblijvend gesprek", "content": "<p>We bellen 30 minuten en kijken of we matchen. Geen verkooppraatje — wel concrete vragen over wat je nodig hebt.</p>" } },
        { "type": "step", "settings": { "title": "Voorbereiding",  "content_title": "Het intaketraject", "content": "<p>In de <strong>twee weken voor vertrek</strong> doe je een persoonlijke voorbereiding: intakevragen, een drijfverentest en een korte schrijfopdracht. Zo arriveer je niet leeg, maar gericht.</p>" } },
        { "type": "step", "settings": { "title": "De retraite",   "content_title": "De dagen zelf", "content": "<p>Begeleide reflectie, beweging, goede gesprekken en stilte — afgewisseld in een ritme dat werkt.</p>" } },
        { "type": "step", "settings": { "title": "Integratie",    "content_title": "Terug in het dagelijks leven", "content": "<p>Een terugkomdag na zes weken om te toetsen wat is geland — en wat een vervolgstap nodig heeft.</p>" } }
      ]
    }
  ]
}
{% endschema %}
