{{ 'kracht-split-hero.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-shero{% if section.settings.bg_image != blank %} kracht-shero--image{% endif %}"
  style="
    --ksh-bg: {{ section.settings.background_color }};
    --ksh-fg: {{ section.settings.text_color }};
    --ksh-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --ksh-radius: {{ section.settings.image_radius }}px;
    --ksh-min-h: {{ section.settings.min_height }}px;
    --ksh-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      srcset="{{ section.settings.bg_image | image_url: width: 1000 }} 1000w, {{ section.settings.bg_image | image_url: width: 1600 }} 1600w, {{ section.settings.bg_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ section.settings.bg_image.alt | escape }}"
      class="kracht-shero__bg"
      loading="eager"
      fetchpriority="high"
    >
    <div class="kracht-shero__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="kracht-shero__inner kracht-container">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="kracht-shero__crumbs" aria-label="Breadcrumb">
        {%- assign crumbs = section.settings.breadcrumbs | default: 'Home / Collecties / Trainingen' | split: '/' -%}
        {%- for c in crumbs -%}
          {%- assign trimmed = c | strip -%}
          {%- if forloop.last -%}
            <span class="is-current">{{ trimmed }}</span>
          {%- else -%}
            <span>{{ trimmed }}</span>
            <span class="kracht-shero__sep" aria-hidden="true">/</span>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="kracht-shero__grid">
      <div class="kracht-shero__content">
        {%- if section.settings.tag != blank -%}
          <span class="kracht-tag kracht-tag--with-plus">{{ section.settings.tag }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="kracht-shero__title">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="kracht-shero__sub">{{ section.settings.subheading }}</div>
        {%- endif -%}

        {%- if section.settings.meta1_label != blank or section.settings.meta2_label != blank or section.settings.meta3_label != blank or section.settings.meta4_label != blank -%}
          <dl class="kracht-shero__meta">
            {%- if section.settings.meta1_label != blank -%}
              <div class="kracht-shero__meta-item"><dt>{{ section.settings.meta1_label }}</dt><dd>{{ section.settings.meta1_value }}</dd></div>
            {%- endif -%}
            {%- if section.settings.meta2_label != blank -%}
              <div class="kracht-shero__meta-item"><dt>{{ section.settings.meta2_label }}</dt><dd>{{ section.settings.meta2_value }}</dd></div>
            {%- endif -%}
            {%- if section.settings.meta3_label != blank -%}
              <div class="kracht-shero__meta-item"><dt>{{ section.settings.meta3_label }}</dt><dd>{{ section.settings.meta3_value }}</dd></div>
            {%- endif -%}
            {%- if section.settings.meta4_label != blank -%}
              <div class="kracht-shero__meta-item"><dt>{{ section.settings.meta4_label }}</dt><dd>{{ section.settings.meta4_value }}</dd></div>
            {%- endif -%}
          </dl>
        {%- endif -%}

        {%- if section.settings.button1_label != blank or section.settings.button2_label != blank -%}
          <div class="kracht-shero__cta">
            {%- if section.settings.button1_label != blank -%}
              <a href="{{ section.settings.button1_link | default: '#' }}" class="kracht-btn kracht-btn--primary">
                {{ section.settings.button1_label }} <span class="kracht-btn__arrow">→</span>
              </a>
            {%- endif -%}
            {%- if section.settings.button2_label != blank -%}
              <a href="{{ section.settings.button2_link | default: '#' }}" class="kracht-btn kracht-btn--outline-dark">
                {{ section.settings.button2_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.bg_image == blank -%}
        <div class="kracht-shero__media">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1200 }}"
              srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 900px) 100vw, 50vw"
              alt="{{ section.settings.image.alt | escape }}"
              class="kracht-shero__img"
              loading="eager"
            >
          {%- else -%}
            <div class="kracht-shero__img kracht-shero__img--ph"></div>
          {%- endif -%}
          {%- if section.settings.show_plus -%}
            <span class="kracht-shero__plus" aria-hidden="true">{% render 'kracht-plus' %}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Split Hero",
  "tag": "section",
  "class": "kracht-shero-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumbs",
      "label": "Breadcrumbs (slash separated)",
      "default": "Home / Collecties / Trainingen"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag pill (optional)"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Voor <strong>groei</strong> heb je <em>Kracht</em> nodig.</p>",
      "info": "Use <strong> for bold, <em> for blue accent."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Onze <strong>trainingen</strong> zijn gemaakt voor teams en professionals die verder willen — niet alleen vakinhoudelijk, maar ook in <strong>samenwerken, leiderschap en communicatie</strong>. Praktisch, persoonlijk en altijd vanuit Kracht.</p>"
    },
    {
      "type": "text",
      "id": "button1_label",
      "label": "Primary button label",
      "default": "Bekijk de trainingen"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary button label",
      "default": "Plan een adviesgesprek"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Metadata strip (optional)",
      "info": "Up to 4 columns shown between the description and the buttons. Leave label empty to hide a column."
    },
    { "type": "text", "id": "meta1_label", "label": "Label 1" },
    { "type": "text", "id": "meta1_value", "label": "Value 1" },
    { "type": "text", "id": "meta2_label", "label": "Label 2" },
    { "type": "text", "id": "meta2_value", "label": "Value 2" },
    { "type": "text", "id": "meta3_label", "label": "Label 3" },
    { "type": "text", "id": "meta3_value", "label": "Value 3" },
    { "type": "text", "id": "meta4_label", "label": "Label 4" },
    { "type": "text", "id": "meta4_value", "label": "Value 4" },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "checkbox",
      "id": "show_plus",
      "label": "Show '+' brand mark on image",
      "default": true
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Full-bleed background (optional)",
      "info": "Set a background image to switch this hero to the full-bleed image style (matches the homepage). When set, the split side image is hidden."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom gradient darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height (full-bleed)",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Kracht — Split Hero"
    }
  ]
}
{% endschema %}
