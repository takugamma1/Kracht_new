{{ 'kracht-split-hero.css' | asset_url | stylesheet_tag }}

{%- assign hero_style = section.settings.hero_style | default: 'default' -%}
{%- assign use_bg = false -%}
{%- assign use_flat = false -%}
{%- if hero_style == 'flat' -%}
  {%- assign use_flat = true -%}
{%- elsif section.settings.bg_image != blank -%}
  {%- assign use_bg = true -%}
{%- endif -%}
{%- assign show_media = false -%}
{%- if use_bg == false and use_flat == false and section.settings.image != blank -%}{%- assign show_media = true -%}{%- endif -%}

<section
  class="kracht-shero{% if use_bg %} kracht-shero--image{% elsif use_flat %} kracht-shero--flat{% endif %}"
  style="
    --ksh-bg: {{ section.settings.background_color }};
    --ksh-fg: {{ section.settings.text_color }};
    --ksh-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --ksh-radius: {{ section.settings.image_radius }}px;
    --ksh-min-h: {{ section.settings.min_height }}px;
    --ksh-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- if use_bg -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      srcset="{{ section.settings.bg_image | image_url: width: 1000 }} 1000w, {{ section.settings.bg_image | image_url: width: 1600 }} 1600w, {{ section.settings.bg_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt="{{ section.settings.bg_image.alt | escape }}"
      class="kracht-shero__bg"
      loading="eager"
      fetchpriority="high"
    >
    <div class="kracht-shero__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="kracht-shero__inner kracht-container">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="kracht-shero__crumbs" aria-label="Breadcrumb">
        {%- assign crumbs = section.settings.breadcrumbs | default: 'Home / Collecties / Trainingen' | split: '/' -%}
        {%- for c in crumbs -%}
          {%- assign trimmed = c | strip -%}
          {%- if forloop.last -%}
            <span class="is-current">{{ trimmed }}</span>
          {%- else -%}
            <span>{{ trimmed }}</span>
            <span class="kracht-shero__sep" aria-hidden="true">/</span>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="kracht-shero__grid">
      <div class="kracht-shero__content">
        {%- if section.settings.tag != blank -%}
          <span class="kracht-tag kracht-tag--with-plus">{{ section.settings.tag }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="kracht-shero__title">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.meta1_value != blank or section.settings.meta1_label != blank or section.settings.meta2_value != blank or section.settings.meta2_label != blank or section.settings.meta3_value != blank or section.settings.meta3_label != blank or section.settings.meta4_value != blank or section.settings.meta4_label != blank -%}
          <div class="kracht-shero__meta">
            {%- if section.settings.meta1_value != blank or section.settings.meta1_label != blank -%}
              <span class="kracht-shero__meta-item"{% if section.settings.meta1_label != blank %} title="{{ section.settings.meta1_label | escape }}"{% endif %}>
                {%- if section.settings.meta1_icon != blank and section.settings.meta1_icon != 'none' -%}<span class="kracht-shero__meta-icon">{% render 'kracht-hero-icon', icon: section.settings.meta1_icon %}</span>{%- endif -%}
                <span class="kracht-shero__meta-val">{{ section.settings.meta1_value | default: section.settings.meta1_label }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.meta2_value != blank or section.settings.meta2_label != blank -%}
              <span class="kracht-shero__meta-item"{% if section.settings.meta2_label != blank %} title="{{ section.settings.meta2_label | escape }}"{% endif %}>
                {%- if section.settings.meta2_icon != blank and section.settings.meta2_icon != 'none' -%}<span class="kracht-shero__meta-icon">{% render 'kracht-hero-icon', icon: section.settings.meta2_icon %}</span>{%- endif -%}
                <span class="kracht-shero__meta-val">{{ section.settings.meta2_value | default: section.settings.meta2_label }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.meta3_value != blank or section.settings.meta3_label != blank -%}
              <span class="kracht-shero__meta-item"{% if section.settings.meta3_label != blank %} title="{{ section.settings.meta3_label | escape }}"{% endif %}>
                {%- if section.settings.meta3_icon != blank and section.settings.meta3_icon != 'none' -%}<span class="kracht-shero__meta-icon">{% render 'kracht-hero-icon', icon: section.settings.meta3_icon %}</span>{%- endif -%}
                <span class="kracht-shero__meta-val">{{ section.settings.meta3_value | default: section.settings.meta3_label }}</span>
              </span>
            {%- endif -%}
            {%- if section.settings.meta4_value != blank or section.settings.meta4_label != blank -%}
              <span class="kracht-shero__meta-item"{% if section.settings.meta4_label != blank %} title="{{ section.settings.meta4_label | escape }}"{% endif %}>
                {%- if section.settings.meta4_icon != blank and section.settings.meta4_icon != 'none' -%}<span class="kracht-shero__meta-icon">{% render 'kracht-hero-icon', icon: section.settings.meta4_icon %}</span>{%- endif -%}
                <span class="kracht-shero__meta-val">{{ section.settings.meta4_value | default: section.settings.meta4_label }}</span>
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="kracht-shero__sub">{{ section.settings.subheading }}</div>
        {%- endif -%}

        {%- if section.settings.button1_label != blank or section.settings.button2_label != blank -%}
          <div class="kracht-shero__cta">
            {%- if section.settings.button1_label != blank -%}
              <a href="{{ section.settings.button1_link | default: '#' }}" class="kracht-btn kracht-btn--primary">
                {{ section.settings.button1_label }} <span class="kracht-btn__arrow">→</span>
              </a>
            {%- endif -%}
            {%- if section.settings.button2_label != blank -%}
              <a href="{{ section.settings.button2_link | default: '#' }}" class="kracht-btn kracht-btn--outline-dark">
                {{ section.settings.button2_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if show_media -%}
        <div class="kracht-shero__media">
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 900px) 100vw, 50vw"
            alt="{{ section.settings.image.alt | escape }}"
            class="kracht-shero__img"
            loading="eager"
          >
          {%- if section.settings.show_plus -%}
            <span class="kracht-shero__plus" aria-hidden="true">{% render 'kracht-plus' %}</span>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Split Hero",
  "tag": "section",
  "class": "kracht-shero-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero style"
    },
    {
      "type": "select",
      "id": "hero_style",
      "label": "Layout",
      "options": [
        { "value": "default", "label": "Default (image → full-bleed, else split)" },
        { "value": "flat", "label": "Flat — dark + diagonal (no photo)" }
      ],
      "default": "default",
      "info": "Choose 'Flat' for the vacancy-style dark hero: diagonal shape, an icon meta row and no photo."
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumbs",
      "label": "Breadcrumbs (slash separated)",
      "default": "Home / Collecties / Trainingen"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag pill (optional)"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Voor <strong>groei</strong> heb je <em>Kracht</em> nodig.</p>",
      "info": "Use <strong> for bold, <em> for blue accent."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Onze <strong>trainingen</strong> zijn gemaakt voor teams en professionals die verder willen — niet alleen vakinhoudelijk, maar ook in <strong>samenwerken, leiderschap en communicatie</strong>. Praktisch, persoonlijk en altijd vanuit Kracht.</p>"
    },
    {
      "type": "text",
      "id": "button1_label",
      "label": "Primary button label",
      "default": "Bekijk de trainingen"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary button label",
      "default": "Plan een adviesgesprek"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Meta row (icon + value)",
      "info": "An inline row shown under the heading. Each item = an icon + a value (the label is used as a tooltip). Leave a value empty to hide it."
    },
    { "type": "text", "id": "meta1_value", "label": "Value 1" },
    { "type": "text", "id": "meta1_label", "label": "Label 1 (tooltip)" },
    { "type": "select", "id": "meta1_icon", "label": "Icon 1", "default": "clock", "options": [
      { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
    { "type": "text", "id": "meta2_value", "label": "Value 2" },
    { "type": "text", "id": "meta2_label", "label": "Label 2 (tooltip)" },
    { "type": "select", "id": "meta2_icon", "label": "Icon 2", "default": "briefcase", "options": [
      { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
    { "type": "text", "id": "meta3_value", "label": "Value 3" },
    { "type": "text", "id": "meta3_label", "label": "Label 3 (tooltip)" },
    { "type": "select", "id": "meta3_icon", "label": "Icon 3", "default": "users", "options": [
      { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
    { "type": "text", "id": "meta4_value", "label": "Value 4" },
    { "type": "text", "id": "meta4_label", "label": "Label 4 (tooltip)" },
    { "type": "select", "id": "meta4_icon", "label": "Icon 4", "default": "euro", "options": [
      { "value": "none", "label": "None" }, { "value": "clock", "label": "Clock (duration)" }, { "value": "briefcase", "label": "Briefcase" }, { "value": "users", "label": "People" }, { "value": "euro", "label": "Euro (price)" }, { "value": "location", "label": "Location" } ] },
    {
      "type": "header",
      "content": "Side image (Default/Split layout only)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "checkbox",
      "id": "show_plus",
      "label": "Show '+' brand mark on image",
      "default": true
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Full-bleed background (optional)",
      "info": "Set a background image to switch this hero to the full-bleed image style (matches the homepage). Ignored when Layout is 'Flat'."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom gradient darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height (full-bleed)",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Kracht — Split Hero"
    }
  ]
}
{% endschema %}
