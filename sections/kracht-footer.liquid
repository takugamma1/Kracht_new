{{ 'kracht-footer.css' | asset_url | stylesheet_tag }}

<footer
  class="kracht-footer"
  style="
    --kft-bg: {{ section.settings.background_color }};
    --kft-fg: {{ section.settings.text_color }};
    --kft-muted: {{ section.settings.muted_color }};
    --kft-pad-y: {{ section.settings.padding_y }}px;
  "
>
  <div class="kracht-footer__inner kracht-container">
    <div class="kracht-footer__grid">
      <!-- Brand -->
      <div class="kracht-footer__col kracht-footer__col--brand">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 320 }}"
            alt="{{ shop.name }}"
            width="160"
            height="auto"
            class="kracht-footer__logo"
            loading="lazy"
          >
        {%- else -%}
          <div class="kracht-footer__logo-text">
            {{ section.settings.logo_text }}<span class="kracht-footer__logo-plus">+</span>
            {%- if section.settings.logo_subtitle != blank -%}
              <span class="kracht-footer__logo-sub">{{ section.settings.logo_subtitle }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if section.settings.brand_text != blank -%}
          <p class="kracht-footer__brand-text">{{ section.settings.brand_text }}</p>
        {%- endif -%}
      </div>

      <!-- Menu blocks -->
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="kracht-footer__col" {{ block.shopify_attributes }}>
              <h3 class="kracht-footer__col-title">{{ block.settings.heading }}</h3>
              {%- assign blk_menu = linklists[block.settings.menu] -%}
              {%- if blk_menu != blank -%}
                <ul class="kracht-footer__list">
                  {%- for link in blk_menu.links -%}
                    <li><a href="{{ link.url }}" class="kracht-footer__link">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- elsif block.settings.links_text != blank -%}
                <ul class="kracht-footer__list">
                  {%- assign lines = block.settings.links_text | newline_to_br | split: '<br />' -%}
                  {%- for line in lines -%}
                    {%- assign trimmed = line | strip -%}
                    {%- if trimmed != blank -%}
                      <li><a href="#" class="kracht-footer__link">{{ trimmed }}</a></li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'contact' -%}
            <div class="kracht-footer__col" {{ block.shopify_attributes }}>
              <h3 class="kracht-footer__col-title">{{ block.settings.heading }}</h3>
              {%- if block.settings.phone != blank -%}
                <a href="tel:{{ block.settings.phone | replace: ' ', '' }}" class="kracht-footer__link">
                  {{ block.settings.phone }}
                </a>
              {%- endif -%}
              {%- if block.settings.email != blank -%}
                <a href="mailto:{{ block.settings.email }}" class="kracht-footer__link">
                  {{ block.settings.email }}
                </a>
              {%- endif -%}
            </div>

          {%- when 'socials' -%}
            <div class="kracht-footer__col kracht-footer__col--socials" {{ block.shopify_attributes }}>
              <h3 class="kracht-footer__col-title">{{ block.settings.heading }}</h3>
              <div class="kracht-footer__socials">
                {%- if block.settings.linkedin != blank -%}
                  <a href="{{ block.settings.linkedin }}" aria-label="LinkedIn" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9.5h4v11H3v-11zM10 9.5h3.8v1.6h.05c.53-1 1.83-2 3.77-2 4.03 0 4.78 2.65 4.78 6.1V20.5h-4v-4.7c0-1.12-.02-2.57-1.57-2.57-1.57 0-1.81 1.22-1.81 2.49V20.5H10v-11z"/></svg></a>
                {%- endif -%}
                {%- if block.settings.instagram != blank -%}
                  <a href="{{ block.settings.instagram }}" aria-label="Instagram" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/></svg></a>
                {%- endif -%}
                {%- if block.settings.facebook != blank -%}
                  <a href="{{ block.settings.facebook }}" aria-label="Facebook" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.6 9.9v-7H8v-2.9h2.4v-2.2c0-2.4 1.4-3.7 3.6-3.7 1 0 2.1.2 2.1.2v2.3h-1.2c-1.2 0-1.6.7-1.6 1.5v1.9h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z"/></svg></a>
                {%- endif -%}
                {%- if block.settings.spotify != blank -%}
                  <a href="{{ block.settings.spotify }}" aria-label="Spotify" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm4.6 14.4a.7.7 0 0 1-1 .2c-2.7-1.7-6.2-2-10.3-1.1a.7.7 0 0 1-.3-1.4c4.4-1 8.2-.6 11.2 1.3.3.2.4.6.2 1zm1.2-2.6a.9.9 0 0 1-1.2.3c-3.1-1.9-7.8-2.4-11.5-1.3a.9.9 0 1 1-.5-1.7c4.2-1.3 9.4-.7 13 1.5.4.3.5.8.2 1.2zm.1-2.7c-3.7-2.2-9.8-2.4-13.3-1.3a1 1 0 1 1-.6-2c4.1-1.2 10.7-1 15 1.6a1 1 0 0 1-1 1.7z"/></svg></a>
                {%- endif -%}
                {%- if block.settings.youtube != blank -%}
                  <a href="{{ block.settings.youtube }}" aria-label="YouTube" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7.5s-.2-1.6-.9-2.3c-.8-.9-1.7-.9-2.2-1C16.6 4 12 4 12 4s-4.6 0-7.9.2c-.5 0-1.4 0-2.2 1C1.2 5.9 1 7.5 1 7.5S.8 9.4.8 11.4v1.4c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.7.2 7.7.2 7.7.2s4.6 0 7.9-.2c.5 0 1.4 0 2.2-1 .7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.4c0-2-.2-3.9-.2-3.9zM9.7 14.7v-5.4l5.6 2.7-5.6 2.7z"/></svg></a>
                {%- endif -%}
                {%- if block.settings.tiktok != blank -%}
                  <a href="{{ block.settings.tiktok }}" aria-label="TikTok" class="kracht-footer__social"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.6a4.6 4.6 0 0 1-3.4-1.5 4.6 4.6 0 0 1-1.2-2.6h-3.3v12.4a2.6 2.6 0 1 1-2.6-2.6c.3 0 .6.1.9.2v-3.4a6 6 0 1 0 5 5.9V8.5a8 8 0 0 0 4.6 1.4V6.6z"/></svg></a>
                {%- endif -%}
              </div>

              {%- if block.settings.cert_heading != blank -%}
                <h3 class="kracht-footer__col-title kracht-footer__col-title--mt">{{ block.settings.cert_heading }}</h3>
                <div class="kracht-footer__certs">
                  {%- if block.settings.cert_image_1 != blank -%}
                    <img src="{{ block.settings.cert_image_1 | image_url: width: 100 }}" alt="" class="kracht-footer__cert" loading="lazy">
                  {%- endif -%}
                  {%- if block.settings.cert_image_2 != blank -%}
                    <img src="{{ block.settings.cert_image_2 | image_url: width: 100 }}" alt="" class="kracht-footer__cert" loading="lazy">
                  {%- endif -%}
                  {%- if block.settings.cert_image_3 != blank -%}
                    <img src="{{ block.settings.cert_image_3 | image_url: width: 100 }}" alt="" class="kracht-footer__cert" loading="lazy">
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {% if section.settings.show_bottom_bar %}
      <hr class="kracht-footer__hr" />
      <div class="kracht-footer__bottom">
        <p>© {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.bottom_text != blank %} · {{ section.settings.bottom_text }}{% endif %}</p>
      </div>
    {% endif %}
  </div>
</footer>

{% schema %}
{
  "name": "Kracht — Footer",
  "tag": "section",
  "class": "kracht-footer-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "kracht"
    },
    {
      "type": "text",
      "id": "logo_subtitle",
      "label": "Logo subtitle",
      "default": "recruitment"
    },
    {
      "type": "textarea",
      "id": "brand_text",
      "label": "Brand description"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted/heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_bottom_bar",
      "label": "Show bottom copyright bar",
      "default": true
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Extra text",
      "default": "Alle rechten voorbehouden"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Snel naar"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu (preferred)"
        },
        {
          "type": "textarea",
          "id": "links_text",
          "label": "Or: text links (one per line)",
          "info": "Used only if no menu is set."
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contactgegevens"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email"
        }
      ]
    },
    {
      "type": "socials",
      "name": "Socials + Certs",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Socials"
        },
        { "type": "url", "id": "linkedin", "label": "LinkedIn URL" },
        { "type": "url", "id": "instagram", "label": "Instagram URL" },
        { "type": "url", "id": "facebook", "label": "Facebook URL" },
        { "type": "url", "id": "spotify", "label": "Spotify URL" },
        { "type": "url", "id": "youtube", "label": "YouTube URL" },
        { "type": "url", "id": "tiktok", "label": "TikTok URL" },
        {
          "type": "header",
          "content": "Certificates"
        },
        {
          "type": "text",
          "id": "cert_heading",
          "label": "Certificates heading",
          "default": "Certificaten"
        },
        { "type": "image_picker", "id": "cert_image_1", "label": "Certificate 1" },
        { "type": "image_picker", "id": "cert_image_2", "label": "Certificate 2" },
        { "type": "image_picker", "id": "cert_image_3", "label": "Certificate 3" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Footer",
      "blocks": [
        { "type": "menu", "settings": { "heading": "Snel naar" } },
        { "type": "menu", "settings": { "heading": "Algemeen" } },
        { "type": "contact", "settings": { "heading": "Contactgegevens", "phone": "026 702 44 90", "email": "werken@vanuitkracht.nl" } },
        { "type": "socials", "settings": { "heading": "Socials" } }
      ]
    }
  ]
}
{% endschema %}
