{{ 'kracht-collection-hero.css' | asset_url | stylesheet_tag }}

{%- assign current_collection = collection -%}
{%- assign hero_title = section.settings.heading | default: current_collection.title -%}
{%- assign hero_text = section.settings.subheading | default: current_collection.description -%}
{%- assign hero_image = section.settings.image | default: current_collection.image -%}
{%- assign b1_label = section.settings.button1_label | default: 'Bekijk de collectie' -%}
{%- assign b2_label = section.settings.button2_label | default: 'Nieuwste eerst' -%}

<section
  class="kracht-coll-hero{% if hero_image != blank %} kracht-coll-hero--image{% endif %}"
  style="
    --kch-bg: {{ section.settings.background_color }};
    --kch-fg: {{ section.settings.text_color }};
    --kch-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --kch-min-height: {{ section.settings.min_height }}px;
    --kch-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- if hero_image != blank -%}
    <img
      src="{{ hero_image | image_url: width: 2400 }}"
      srcset="
        {{ hero_image | image_url: width: 800 }} 800w,
        {{ hero_image | image_url: width: 1200 }} 1200w,
        {{ hero_image | image_url: width: 1600 }} 1600w,
        {{ hero_image | image_url: width: 2400 }} 2400w
      "
      sizes="100vw"
      alt="{{ hero_image.alt | default: hero_title | strip_html }}"
      class="kracht-coll-hero__bg"
      loading="eager"
      fetchpriority="high"
    >
    <div class="kracht-coll-hero__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="kracht-coll-hero__inner kracht-container">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="kracht-coll-hero__crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="kracht-coll-hero__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
        <a href="{{ routes.collections_url }}">Collecties</a>
        {%- if current_collection != blank -%}
          <span class="kracht-coll-hero__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
          <span class="is-current">{{ current_collection.title }}</span>
        {%- endif -%}
      </nav>
    {%- endif -%}

    <div class="kracht-coll-hero__content">
      {%- if section.settings.tag != blank -%}
        <span class="kracht-tag kracht-coll-hero__tag">{{ section.settings.tag }}</span>
      {%- endif -%}
      {%- if hero_title != blank -%}
        <h1 class="kracht-coll-hero__title">{{ hero_title }}</h1>
      {%- endif -%}
      {%- if hero_text != blank -%}
        <p class="kracht-coll-hero__sub">{{ hero_text }}</p>
      {%- endif -%}
      {%- if b1_label != blank or b2_label != blank -%}
        <div class="kracht-coll-hero__cta">
          {%- if b1_label != blank -%}
            <a href="{{ section.settings.button1_link | default: '#' }}" class="kracht-btn kracht-btn--primary">
              {{ b1_label }} <span class="kracht-btn__arrow">→</span>
            </a>
          {%- endif -%}
          {%- if b2_label != blank -%}
            <a href="{{ section.settings.button2_link | default: '#' }}" class="kracht-btn kracht-btn--outline-dark">
              {{ b2_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Collection Hero",
  "tag": "section",
  "class": "kracht-coll-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "If empty, uses the collection image. If neither is set, the hero stays a solid color."
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height (with image)",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom gradient darkness",
      "info": "Darkens the bottom of the image so the heading + buttons stay readable. Fades to clear towards the top.",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag pill",
      "default": "Kracht+ Collectie"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading override",
      "info": "If empty, uses the collection title."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading override",
      "info": "If empty, uses the collection description.",
      "default": "<p><strong>Premium kleding</strong> voor het team dat altijd wint. Van werkkleding tot lifestyle — <strong>met trots gedragen</strong> door het hele Kracht team.</p>"
    },
    {
      "type": "text",
      "id": "button1_label",
      "label": "Primary button label",
      "default": "Bekijk de collectie"
    },
    {
      "type": "url",
      "id": "button1_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary button label",
      "default": "Nieuwste eerst"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding (no image)",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Kracht — Collection Hero"
    }
  ]
}
{% endschema %}
