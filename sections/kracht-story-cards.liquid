{{ 'kracht-story-cards.css' | asset_url | stylesheet_tag }}

<section
  id="kracht-stories-{{ section.id }}"
  class="kracht-stories"
  style="
    --kst-bg: {{ section.settings.background_color }};
    --kst-fg: {{ section.settings.text_color }};
    --kst-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --kst-radius: {{ section.settings.radius }}px;
    --kst-grad: {{ section.settings.gradient_strength | divided_by: 100.0 }};
  "
  data-stories
  data-total="{{ section.blocks.size }}"
>
  <div class="kracht-stories__inner kracht-container">
    <div class="kracht-section__head">
      <div class="kracht-section__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-stories__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.show_arrows -%}
        <div class="kracht-stories__nav">
          <button type="button" class="kracht-stories__arrow" data-dir="-1" aria-label="Vorige">←</button>
          <button type="button" class="kracht-stories__arrow" data-dir="1" aria-label="Volgende">→</button>
        </div>
      {%- endif -%}
    </div>

    <div class="kracht-stories__rail">
      <div class="kracht-stories__track">
        {%- for block in section.blocks -%}
          <a class="kracht-story-card" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 480 }} 480w, {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 768px) 80vw, 33vw"
                alt="{{ block.settings.image.alt | default: block.settings.title }}"
                class="kracht-story-card__img"
                loading="lazy"
              >
            {%- else -%}
              <div class="kracht-story-card__img kracht-story-card__img--ph"></div>
            {%- endif -%}
            <div class="kracht-story-card__overlay" aria-hidden="true"></div>
            <div class="kracht-story-card__body">
              {%- if block.settings.tag_date != blank -%}
                <div class="kracht-story-card__meta">
                  <span class="kracht-story-card__date">{{ block.settings.tag_date }}</span>
                </div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <p class="kracht-story-card__title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.cta != blank -%}
                <span class="kracht-story-card__cta">{{ block.settings.cta }} <span aria-hidden="true">→</span></span>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_progress -%}
      <div class="kracht-stories__progress" data-stories-progress>
        <span class="kracht-stories__bar"><span class="kracht-stories__bar-fill" data-stories-fill></span></span>
        <span class="kracht-stories__count" data-stories-count>01 / {{ section.blocks.size | prepend: '0' | slice: -2, 2 }}</span>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('kracht-stories-{{ section.id }}');
    if (!root) return;
    const rail = root.querySelector('.kracht-stories__rail');
    const track = root.querySelector('.kracht-stories__track');
    if (!rail || !track) return;

    const arrows = root.querySelectorAll('.kracht-stories__arrow');
    const fill = root.querySelector('[data-stories-fill]');
    const count = root.querySelector('[data-stories-count]');
    const total = parseInt(root.dataset.total || '0', 10);

    const pad2 = (n) => String(n).padStart(2, '0');

    function cardStep() {
      const first = root.querySelector('.kracht-story-card');
      if (!first) return rail.clientWidth;
      const gap = parseFloat(getComputedStyle(track).columnGap || '0') || 0;
      return first.offsetWidth + gap;
    }

    function maxScroll() {
      return Math.max(0, rail.scrollWidth - rail.clientWidth);
    }

    function isScrollable() {
      return maxScroll() > 2;
    }

    function update() {
      const max = maxScroll();
      const pct = max > 0 ? Math.min(100, Math.max(0, (rail.scrollLeft / max) * 100)) : 100;
      if (fill) fill.style.setProperty('--kst-progress', pct + '%');
      if (count && total > 0) {
        const step = cardStep();
        const current = step > 0 ? Math.min(total, Math.max(1, Math.round(rail.scrollLeft / step) + 1)) : 1;
        count.textContent = pad2(current) + ' / ' + pad2(total);
      }
      /* Hide controls entirely when there's nothing to scroll. */
      root.classList.toggle('is-static', !isScrollable());
    }

    arrows.forEach((b) => {
      b.addEventListener('click', () => {
        const dir = parseInt(b.dataset.dir, 10) || 1;
        rail.scrollBy({ left: dir * cardStep(), behavior: 'smooth' });
      });
    });

    rail.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
    window.addEventListener('resize', () => requestAnimationFrame(update));
    update();
  })();
</script>

{% schema %}
{
  "name": "Kracht — Story Cards",
  "tag": "section",
  "class": "kracht-stories-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Verhalen vanuit Kracht"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Meer dan <strong>merch.</strong></p>"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show prev/next arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show progress bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "gradient_strength",
      "label": "Card gradient strength",
      "info": "How dark the bottom of each card becomes. 100 = full black panel, 0 = no overlay.",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag_label", "label": "Tag label", "default": "Team" },
        { "type": "text", "id": "tag_date", "label": "Date / right meta", "default": "12 mei 2026" },
        { "type": "text", "id": "title", "label": "Title", "default": "Hoe het Kracht team samen wint." },
        { "type": "text", "id": "cta", "label": "CTA label", "default": "Lees meer" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Story Cards",
      "blocks": [
        { "type": "story", "settings": { "tag_label": "Team",      "tag_date": "12 mei 2026", "title": "Hoe het Kracht team samen wint.", "cta": "Lees meer" } },
        { "type": "story", "settings": { "tag_label": "Cultuur",   "tag_date": "28 apr 2026", "title": "Werken vanuit Kracht — wat dat écht betekent.", "cta": "Lees meer" } },
        { "type": "story", "settings": { "tag_label": "Stijl",     "tag_date": "15 apr 2026", "title": "Van werkkleding tot lifestyle.", "cta": "Lees meer" } },
        { "type": "story", "settings": { "tag_label": "Kandidaten","tag_date": "",            "title": "Van een goede naar een betere baan.", "cta": "Lees meer" } }
      ]
    }
  ]
}
{% endschema %}
