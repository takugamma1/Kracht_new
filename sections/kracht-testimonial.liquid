{{ 'kracht-testimonial.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-test"
  id="kracht-test-{{ section.id }}"
  data-kracht-carousel
  data-autoplay="{{ section.settings.autoplay_seconds }}"
  style="
    --kt-bg: {{ section.settings.background_color }};
    --kt-fg: {{ section.settings.text_color }};
    --kt-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
  "
>
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.intro != blank -%}
    <div class="kracht-test__inner kracht-container">
      <div class="kracht-test__head">
        <div class="kracht-test__head-left">
          {%- if section.settings.eyebrow != blank -%}
            <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="kracht-test__title">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.intro != blank -%}
          <div class="kracht-test__intro">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

  <div class="kracht-test__carousel">
    <div class="kracht-test__track" data-kracht-track>
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="kracht-test__slide" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1800 }}"
                srcset="{{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1800 }} 1800w"
                sizes="100vw"
                alt="{{ block.settings.image.alt | escape }}"
                class="kracht-test__img"
                loading="lazy"
              >
            {%- else -%}
              <div class="kracht-test__img kracht-test__img--ph"></div>
            {%- endif -%}
            <article class="kracht-test__card">
              {%- if block.settings.tag != blank -%}
                <span class="kracht-tag kracht-test__pill">{{ block.settings.tag }}</span>
              {%- endif -%}
              {%- if block.settings.meta != blank -%}
                <p class="kracht-test__meta">{{ block.settings.meta }}</p>
              {%- endif -%}
              {%- if block.settings.quote != blank -%}
                <blockquote class="kracht-test__quote">{{ block.settings.quote }}</blockquote>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_link | default: '#' }}" class="kracht-test__cta">
                  {{ block.settings.cta_label }} <span aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            </article>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback: render the legacy single story so nothing goes blank before slides are added as blocks. {%- endcomment -%}
        <div class="kracht-test__slide">
          {%- if section.settings.image != blank -%}
            <img
              src="{{ section.settings.image | image_url: width: 1800 }}"
              srcset="{{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1800 }} 1800w"
              sizes="100vw"
              alt="{{ section.settings.image.alt | escape }}"
              class="kracht-test__img"
              loading="lazy"
            >
          {%- else -%}
            <div class="kracht-test__img kracht-test__img--ph"></div>
          {%- endif -%}
          <article class="kracht-test__card">
            {%- if section.settings.card_tag != blank -%}
              <span class="kracht-tag kracht-test__pill">{{ section.settings.card_tag }}</span>
            {%- endif -%}
            {%- if section.settings.card_meta != blank -%}
              <p class="kracht-test__meta">{{ section.settings.card_meta }}</p>
            {%- endif -%}
            {%- if section.settings.card_quote != blank -%}
              <blockquote class="kracht-test__quote">{{ section.settings.card_quote }}</blockquote>
            {%- endif -%}
            {%- if section.settings.card_cta != blank -%}
              <a href="{{ section.settings.card_cta_link | default: '#' }}" class="kracht-test__cta">
                {{ section.settings.card_cta }} <span aria-hidden="true">→</span>
              </a>
            {%- endif -%}
          </article>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="kracht-test__dots" role="tablist" aria-label="Succesverhalen">
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="kracht-test__dot{% if forloop.first %} is-active{% endif %}"
          data-kracht-dot="{{ forloop.index0 }}"
          role="tab"
          aria-label="Verhaal {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.getElementById('kracht-test-{{ section.id }}');
    if (!root || root.dataset.kchtInit) return;
    root.dataset.kchtInit = '1';
    var track = root.querySelector('[data-kracht-track]');
    var slides = root.querySelectorAll('.kracht-test__slide');
    var dots = root.querySelectorAll('[data-kracht-dot]');
    if (!track || slides.length < 2) return;
    var idx = 0, timer = null;
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var delay = parseInt(root.getAttribute('data-autoplay'), 10) || 0;
    var editor = window.Shopify && window.Shopify.designMode;
    function show(n) {
      idx = (n + slides.length) % slides.length;
      track.style.transform = 'translateX(-' + (idx * 100) + '%)';
      for (var d = 0; d < dots.length; d++) {
        dots[d].classList.toggle('is-active', d === idx);
        dots[d].setAttribute('aria-selected', d === idx ? 'true' : 'false');
      }
    }
    for (var k = 0; k < dots.length; k++) {
      (function (n) {
        dots[n].addEventListener('click', function () { show(n); restart(); });
      })(k);
    }
    function start() {
      if (delay > 0 && !reduce && !editor) {
        timer = setInterval(function () { show(idx + 1); }, delay * 1000);
      }
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }
    function restart() { stop(); start(); }
    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    root.addEventListener('focusin', stop);
    root.addEventListener('focusout', start);
    show(0);
    start();
  })();
</script>

{% schema %}
{
  "name": "Kracht — Testimonial",
  "tag": "section",
  "class": "kracht-test-section",
  "settings": [
    {
      "type": "header",
      "content": "Header (optional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "range",
      "id": "autoplay_seconds",
      "label": "Autoplay seconds (0 = off)",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "header",
      "content": "Fallback story",
      "info": "Shown only when no slides are added below. Add 'Story' slides to build the carousel."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "card_tag",
      "label": "Tag",
      "default": "Succesverhaal"
    },
    {
      "type": "text",
      "id": "card_meta",
      "label": "Name / role",
      "default": "Ted Maters · Architect"
    },
    {
      "type": "richtext",
      "id": "card_quote",
      "label": "Quote",
      "default": "<p>\"Hoe Ted via Kracht terechtkwam bij het architectenbureau van zijn <strong>oud-docent.</strong>\"</p>"
    },
    {
      "type": "text",
      "id": "card_cta",
      "label": "CTA label",
      "default": "Lees meer"
    },
    {
      "type": "url",
      "id": "card_cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Succesverhaal"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Name / role",
          "default": "Naam · Functie"
        },
        {
          "type": "richtext",
          "id": "quote",
          "label": "Quote",
          "default": "<p>\"Een korte, krachtige quote van de klant.\"</p>"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Lees meer"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Testimonial",
      "blocks": [
        { "type": "story", "settings": { "meta": "Stijn", "quote": "<p>\"SkaaL was de eerste en daar ben ik blijven hangen. We hadden direct zo'n goede klik.\"</p>" } },
        { "type": "story", "settings": { "meta": "Ted Maters · Architect", "quote": "<p>\"Hoe Ted via Kracht terechtkwam bij het architectenbureau van zijn <strong>oud-docent.</strong>\"</p>" } },
        { "type": "story", "settings": { "meta": "Lisa · Recruiter", "quote": "<p>\"Persoonlijk, betrokken en altijd vanuit Kracht.\"</p>" } }
      ]
    }
  ]
}
{% endschema %}
