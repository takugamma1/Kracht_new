{{ 'kracht-trainer-profile.css' | asset_url | stylesheet_tag }}
{%- comment -%} Reference layout: long text on the LEFT of the page; on the RIGHT an aside heading ("Meer weten?") above a compact black contact card — photo melting into the panel, name, phone/WhatsApp/email rows, blue button. {%- endcomment -%}

<section
  class="kracht-tprof"
  style="
    --ktp-bg: {{ section.settings.background_color }};
    --ktp-fg: {{ section.settings.text_color }};
    --ktp-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --ktp-radius: {{ section.settings.image_radius }}px;
  "
>
  <div class="kracht-tprof__inner kracht-container">
    <div class="kracht-tprof__grid">
      <div class="kracht-tprof__main">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.name != blank -%}
          <h2 class="kracht-tprof__name">{{ section.settings.name }}</h2>
        {%- endif -%}
        {%- if section.settings.bio != blank -%}
          <div class="kracht-tprof__bio">{{ section.settings.bio }}</div>
        {%- endif -%}
        {%- if section.settings.bio2 != blank -%}
          <div class="kracht-tprof__bio">{{ section.settings.bio2 }}</div>
        {%- endif -%}
      </div>

      <div class="kracht-tprof__aside">
        {%- if section.settings.aside_heading != blank -%}
          <h2 class="kracht-tprof__aside-title">{{ section.settings.aside_heading }}</h2>
        {%- endif -%}

        <div class="kracht-tprof__card">
          <div class="kracht-tprof__media">
            {%- if section.settings.image != blank -%}
              <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 800 }} 800w"
                sizes="(max-width: 900px) 100vw, 30vw"
                alt="{{ section.settings.image.alt | default: section.settings.card_name | escape }}"
                class="kracht-tprof__img"
                loading="lazy"
              >
            {%- else -%}
              <div class="kracht-tprof__img kracht-tprof__img--ph"></div>
            {%- endif -%}
          </div>

          <div class="kracht-tprof__body">
            {%- if section.settings.card_name != blank -%}
              <p class="kracht-tprof__card-name">{{ section.settings.card_name }}</p>
            {%- endif -%}
            {%- if section.settings.subtitle != blank -%}
              <p class="kracht-tprof__sub">{{ section.settings.subtitle }}</p>
            {%- endif -%}

            {%- if section.settings.location != blank or section.settings.phone != blank or section.settings.whatsapp != blank or section.settings.email != blank -%}
              <div class="kracht-tprof__contacts">
                {%- if section.settings.location != blank -%}
                  <span class="kracht-tprof__contact kracht-tprof__contact--plain">
                    <span class="kracht-tprof__contact-icon">{% render 'kracht-hero-icon', icon: 'location' %}</span>
                    <span>{{ section.settings.location }}</span>
                  </span>
                {%- endif -%}
                {%- if section.settings.phone != blank -%}
                  <a class="kracht-tprof__contact" href="tel:{{ section.settings.phone | remove: ' ' }}">
                    <span class="kracht-tprof__contact-icon">{% render 'kracht-hero-icon', icon: 'phone' %}</span>
                    <span>{{ section.settings.phone }}</span>
                  </a>
                {%- endif -%}
                {%- if section.settings.whatsapp != blank -%}
                  {%- assign wa_digits = section.settings.whatsapp | remove: ' ' | remove: '+' | remove: '(' | remove: ')' | remove: '-' -%}
                  <a class="kracht-tprof__contact" href="https://wa.me/{{ wa_digits }}" target="_blank" rel="noopener">
                    <span class="kracht-tprof__contact-icon">{% render 'kracht-hero-icon', icon: 'whatsapp' %}</span>
                    <span>{{ section.settings.whatsapp }}</span>
                  </a>
                {%- endif -%}
                {%- if section.settings.email != blank -%}
                  <a class="kracht-tprof__contact" href="mailto:{{ section.settings.email }}">
                    <span class="kracht-tprof__contact-icon">{% render 'kracht-hero-icon', icon: 'mail' %}</span>
                    <span>{{ section.settings.email }}</span>
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if section.settings.button_label != blank -%}
              <a href="{{ section.settings.button_link | default: '/pages/contact' }}" class="kracht-btn kracht-btn--primary kracht-tprof__btn">
                {{ section.settings.button_label }} <span class="kracht-btn__arrow">→</span>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Trainer Profile",
  "tag": "section",
  "class": "kracht-tprof-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Left column (text)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Jouw trainer"
    },
    {
      "type": "richtext",
      "id": "name",
      "label": "Heading",
      "default": "<p>Maak kennis met <strong>Mark.</strong></p>"
    },
    {
      "type": "richtext",
      "id": "bio",
      "label": "Bio paragraph",
      "default": "<p>Mark traint al 14 jaar teams in de technische en bouwsector. Hij combineert een achtergrond in <strong>organisatiepsychologie</strong> met praktische ervaring als projectleider. Werkt eerder gedaan voor <strong>Heijmans, BAM en Witteveen+Bos</strong>.</p>"
    },
    {
      "type": "richtext",
      "id": "bio2",
      "label": "Extra bio paragraphs",
      "default": "<p>Zijn aanpak is praktisch en persoonlijk: geen standaardverhaal, maar oefenen met situaties uit jullie eigen werkpraktijk. Mark is <strong>Lencioni-gecertificeerd</strong> en geeft trainingen in het <strong>Nederlands, Engels en Duits</strong>.</p><p>Deelnemers omschrijven hem als direct, betrokken en scherp — iemand die benoemt wat er speelt en het team daarna zélf aan het werk zet.</p>"
    },
    {
      "type": "header",
      "content": "Contact card (right column)"
    },
    {
      "type": "text",
      "id": "aside_heading",
      "label": "Aside heading",
      "default": "Meer weten?"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Portrait image"
    },
    {
      "type": "text",
      "id": "card_name",
      "label": "Name on the card",
      "default": "Mark"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle / role",
      "default": "Senior Trainer & Teamcoach"
    },
    {
      "type": "text",
      "id": "location",
      "label": "Location",
      "default": "Arnhem · Hoofdkantoor Kracht",
      "info": "Shown with the location icon."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "06 12 34 56 78",
      "info": "Shown with the phone icon; links via tel:."
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number",
      "default": "06 12 34 56 78",
      "info": "Shown with the WhatsApp icon; links via wa.me."
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-mail address",
      "default": "mark@vanuitkracht.nl",
      "info": "Shown with the mail icon; links via mailto:."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Meer informatie"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Falls back to /pages/contact when empty."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 140
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Chip / tag",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Org. Psychologie" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Trainer Profile"
    }
  ]
}
{% endschema %}
