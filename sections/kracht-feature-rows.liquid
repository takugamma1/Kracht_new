{{ 'kracht-feature-rows.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-frows"
  style="
    --kfr-bg: {{ section.settings.background_color }};
    --kfr-fg: {{ section.settings.text_color }};
    --kfr-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --kfr-radius: {{ section.settings.image_radius }}px;
  "
>
  <div class="kracht-frows__inner kracht-container">
    <div class="kracht-frows__head">
      <div class="kracht-frows__head-left">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-frows__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.intro != blank -%}
        <div class="kracht-frows__intro">{{ section.settings.intro }}</div>
      {%- endif -%}
    </div>

    <div class="kracht-frows__carousel">
      <ul class="kracht-frows__track" role="list">
        {%- for block in section.blocks -%}
          <li class="kracht-frow-card" {{ block.shopify_attributes }}>
            <div class="kracht-frow-card__media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 900px) 90vw, 33vw"
                  alt="{{ block.settings.image.alt | escape }}"
                  class="kracht-frow-card__img"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kracht-frow-card__img kracht-frow-card__img--ph"></div>
              {%- endif -%}

              {%- if block.settings.tag != blank -%}
                <span class="kracht-tag kracht-tag--with-plus kracht-frow-card__badge">{{ block.settings.tag }}</span>
              {%- endif -%}
            </div>

            <div class="kracht-frow-card__body">
              {%- if block.settings.eyebrow != blank -%}
                <span class="kracht-eyebrow kracht-frow-card__eyebrow">{{ block.settings.eyebrow }}</span>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="kracht-frow-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="kracht-frow-card__desc">{{ block.settings.description }}</p>
              {%- endif -%}

              {%- if block.settings.meta1_label != blank or block.settings.meta2_label != blank or block.settings.meta3_label != blank -%}
                <dl class="kracht-frow-card__meta">
                  {%- if block.settings.meta1_label != blank -%}
                    <div class="kracht-frow-card__meta-item"><dt>{{ block.settings.meta1_label }}</dt><dd>{{ block.settings.meta1_value }}</dd></div>
                  {%- endif -%}
                  {%- if block.settings.meta2_label != blank -%}
                    <div class="kracht-frow-card__meta-item"><dt>{{ block.settings.meta2_label }}</dt><dd>{{ block.settings.meta2_value }}</dd></div>
                  {%- endif -%}
                  {%- if block.settings.meta3_label != blank -%}
                    <div class="kracht-frow-card__meta-item"><dt>{{ block.settings.meta3_label }}</dt><dd>{{ block.settings.meta3_value }}</dd></div>
                  {%- endif -%}
                </dl>
              {%- endif -%}

              {%- if block.settings.button1_label != blank -%}
                <a href="{{ block.settings.button1_link | default: '#' }}" class="kracht-frow-card__more">
                  {{ block.settings.button1_label }} <span aria-hidden="true">→</span>
                </a>
              {%- endif -%}

              {%- if block.settings.button2_label != blank -%}
                <a href="{{ block.settings.button2_link | default: '#' }}" class="kracht-frow-card__more kracht-frow-card__more--alt">
                  {{ block.settings.button2_label }} <span aria-hidden="true">→</span>
                </a>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Feature Rows",
  "tag": "section",
  "class": "kracht-frows-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Onze trainingen"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Drie programma's,<br><strong>één missie: <em>groei.</em></strong></p>",
      "info": "Use <strong> for bold, <em> for blue accent."
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro paragraph",
      "default": "<p>Elke training is op maat te maken voor jouw team of organisatie. Klassikaal, online of hybride — altijd persoonlijk, altijd praktisch.</p>"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "tag", "label": "Tag (e.g. 02)", "default": "01" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "" },
        { "type": "text", "id": "title", "label": "Title", "default": "Samenwerken vanuit Kracht." },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Bouw een team dat écht samenwerkt. Van vertrouwen tot gedeelde verantwoordelijkheid — krachtiger als groep dan als optelsom van individuen." },
        { "type": "header", "content": "Metadata (optional, 3 columns)" },
        { "type": "text", "id": "meta1_label", "label": "Label 1", "default": "" },
        { "type": "text", "id": "meta1_value", "label": "Value 1", "default": "" },
        { "type": "text", "id": "meta2_label", "label": "Label 2", "default": "" },
        { "type": "text", "id": "meta2_value", "label": "Value 2", "default": "" },
        { "type": "text", "id": "meta3_label", "label": "Label 3", "default": "" },
        { "type": "text", "id": "meta3_value", "label": "Value 3", "default": "" },
        { "type": "header", "content": "Links" },
        { "type": "text", "id": "button1_label", "label": "Primary link label", "default": "Meer info" },
        { "type": "url", "id": "button1_link", "label": "Primary link URL" },
        { "type": "text", "id": "button2_label", "label": "Secondary link label", "default": "" },
        { "type": "url", "id": "button2_link", "label": "Secondary link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Feature Rows",
      "blocks": [
        { "type": "row", "settings": { "tag": "01", "eyebrow": "2.1.1 — Samenwerking", "title": "Samenwerken vanuit Kracht." } },
        { "type": "row", "settings": { "tag": "02", "eyebrow": "2.1.2 — Leiderschap",  "title": "Leiden vanuit Kracht.",     "description": "Ontwikkel een authentieke leiderschapsstijl. Effectief delegeren en het beste uit je team halen." } },
        { "type": "row", "settings": { "tag": "03", "eyebrow": "2.1.3 — Communicatie", "title": "Heldere taal, scherpe boodschap.", "description": "Leer écht luisteren, helder overtuigen en feedback geven die bijdraagt aan groei." } }
      ]
    }
  ]
}
{% endschema %}
