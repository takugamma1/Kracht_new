{{ 'kracht-team-grid.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-team"
  style="
    --ktg-bg: {{ section.settings.background_color }};
    --ktg-fg: {{ section.settings.text_color }};
    --ktg-card-bg: {{ section.settings.card_color }};
    --ktg-card-fg: {{ section.settings.card_text_color }};
    --ktg-cta-bg-from: {{ section.settings.cta_color_from }};
    --ktg-cta-bg-to: {{ section.settings.cta_color_to }};
    --ktg-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
    --ktg-radius: {{ section.settings.radius }}px;
  "
>
  <div class="kracht-team__inner kracht-container">
    {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
      <div class="kracht-team__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-team__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kracht-team__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trainer' -%}
          <article class="kracht-team__card kracht-team__card--trainer" {{ block.shopify_attributes }}>
            <div class="kracht-team__photo">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 900px) 50vw, 25vw"
                  alt="{{ block.settings.name | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="kracht-team__photo--ph"></div>
              {%- endif -%}
              <div class="kracht-team__photo-shade" aria-hidden="true"></div>
            </div>

            <div class="kracht-team__body">
              {%- if block.settings.name != blank -%}
                <p class="kracht-team__name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.role != blank -%}
                <p class="kracht-team__role">{{ block.settings.role }}</p>
              {%- endif -%}
              {%- if block.settings.subline != blank -%}
                <p class="kracht-team__subline">{{ block.settings.subline }}</p>
              {%- endif -%}

              {%- if block.settings.email != blank or block.settings.phone != blank or block.settings.whatsapp != blank -%}
                <ul class="kracht-team__contact">
                  {%- if block.settings.email != blank -%}
                    <li>
                      <a href="mailto:{{ block.settings.email }}" aria-label="Email {{ block.settings.name | escape }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                          <rect x="3" y="5" width="18" height="14" rx="2"/>
                          <path d="M3 7l9 6 9-6"/>
                        </svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.phone != blank -%}
                    <li>
                      <a href="tel:{{ block.settings.phone | remove: ' ' }}" aria-label="Bel {{ block.settings.name | escape }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                        </svg>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.whatsapp != blank -%}
                    {%- assign wa_num = block.settings.whatsapp | remove: ' ' | remove: '+' | remove: '-' -%}
                    <li>
                      <a href="https://wa.me/{{ wa_num }}" target="_blank" rel="noopener" aria-label="WhatsApp {{ block.settings.name | escape }}">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                          <path d="M20.52 3.48A11.82 11.82 0 0 0 12.06 0C5.5 0 .17 5.34.17 11.9c0 2.1.55 4.15 1.6 5.95L0 24l6.32-1.66a11.92 11.92 0 0 0 5.73 1.46h.01c6.56 0 11.89-5.34 11.89-11.9 0-3.18-1.24-6.17-3.43-8.42zM12.06 21.78h-.01a9.85 9.85 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.87 9.87 0 0 1-1.51-5.26c0-5.45 4.43-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.83 9.83 0 0 1 2.9 7c0 5.45-4.44 9.88-9.89 9.88zm5.4-7.4c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.07-.3-.15-1.26-.46-2.4-1.47-.88-.79-1.48-1.76-1.65-2.06-.18-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.03-.52-.07-.15-.66-1.6-.9-2.2-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.87 1.21 3.07c.15.2 2.1 3.2 5.08 4.48.71.3 1.27.49 1.7.62.72.22 1.36.2 1.87.12.57-.09 1.76-.72 2-1.41.25-.69.25-1.29.18-1.41-.07-.13-.27-.2-.57-.35z"/>
                        </svg>
                      </a>
                    </li>
                  {%- endif -%}
                </ul>
              {%- endif -%}
            </div>
          </article>
        {%- elsif block.type == 'cta' -%}
          <article class="kracht-team__card kracht-team__card--cta" {{ block.shopify_attributes }}>
            <div class="kracht-team__cta-body">
              {%- if block.settings.heading != blank -%}
                <p class="kracht-team__cta-title">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="kracht-team__cta-text">{{ block.settings.body }}</div>
              {%- endif -%}
            </div>
            {%- if block.settings.button_label != blank -%}
              <a
                href="{{ block.settings.button_link | default: '#' }}"
                class="kracht-btn kracht-btn--dark kracht-team__cta-btn"
                {%- if block.settings.open_in_new_tab %} target="_blank" rel="noopener"{% endif -%}
              >
                {%- if block.settings.open_in_new_tab -%}
                  <span class="kracht-team__cta-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4h6v6"/><path d="M20 4L10 14"/><path d="M19 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6"/></svg>
                  </span>
                {%- endif -%}
                {{ block.settings.button_label }}
              </a>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.bottom_button_label != blank -%}
      <div class="kracht-team__foot">
        <a href="{{ section.settings.bottom_button_link | default: '#' }}" class="kracht-btn kracht-btn--primary kracht-team__foot-btn">
          {{ section.settings.bottom_button_label }} <span class="kracht-btn__arrow">→</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Team Grid",
  "tag": "section",
  "class": "kracht-team-section",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Section header" },
    { "type": "text",     "id": "eyebrow", "label": "Eyebrow" },
    { "type": "richtext", "id": "heading", "label": "Heading", "default": "<p>Ons team</p>" },

    { "type": "header", "content": "Bottom button" },
    { "type": "text", "id": "bottom_button_label", "label": "Button label", "default": "Maak kennis met ons team" },
    { "type": "url",  "id": "bottom_button_link",  "label": "Button link" },

    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color",  "label": "Background color",      "default": "#f4f4f5" },
    { "type": "color", "id": "text_color",        "label": "Text color",            "default": "#000000" },
    { "type": "color", "id": "card_color",        "label": "Trainer card background", "default": "#000000" },
    { "type": "color", "id": "card_text_color",   "label": "Trainer card text",     "default": "#ffffff" },
    { "type": "color", "id": "cta_color_from",    "label": "CTA gradient — top",    "default": "#2bb1ec" },
    { "type": "color", "id": "cta_color_to",      "label": "CTA gradient — bottom", "default": "#009de1" },
    { "type": "range", "id": "padding_y",         "label": "Vertical padding", "min": 24, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "radius",            "label": "Card radius",      "min": 0, "max": 32, "step": 1, "unit": "px", "default": 14 }
  ],
  "blocks": [
    {
      "type": "trainer",
      "name": "Trainer",
      "settings": [
        { "type": "image_picker", "id": "image",    "label": "Photo" },
        { "type": "text",         "id": "name",     "label": "Name",     "default": "Wout Wikkerink" },
        { "type": "text",         "id": "role",     "label": "Role",     "default": "Consultant Civiele Techniek" },
        { "type": "text",         "id": "subline",  "label": "Subline / Region", "default": "Regio Zuidwest" },
        { "type": "header", "content": "Contact" },
        { "type": "text",         "id": "email",    "label": "Email" },
        { "type": "text",         "id": "phone",    "label": "Phone" },
        { "type": "text",         "id": "whatsapp", "label": "WhatsApp number (international format)" }
      ]
    },
    {
      "type": "cta",
      "name": "CTA card",
      "settings": [
        { "type": "text",     "id": "heading",      "label": "Heading",      "default": "Pas jij bij ons?" },
        { "type": "richtext", "id": "body",         "label": "Body",         "default": "<p>Wil jij ook duizenden professionals in de bouw en techniek van een goede naar een betere baan helpen? Sluit je aan bij ons vriendenteam en ontdek waarom werken bij Kracht meer is dan alleen een baan.</p>" },
        { "type": "text",     "id": "button_label", "label": "Button label", "default": "Interne vacatures" },
        { "type": "url",      "id": "button_link",  "label": "Button link" },
        { "type": "checkbox", "id": "open_in_new_tab", "label": "Open link in new tab (shows external icon)", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Team Grid",
      "blocks": [
        { "type": "trainer" },
        { "type": "trainer", "settings": { "name": "Koen de Bruijn",  "role": "Trainer", "subline": "" } },
        { "type": "trainer", "settings": { "name": "Nils van Schaik", "role": "Captain Civiele Techniek", "subline": "Regio Noord, Midden & Oost" } },
        { "type": "cta" }
      ]
    }
  ]
}
{% endschema %}
