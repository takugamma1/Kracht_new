{{ 'kracht-product-grid.css' | asset_url | stylesheet_tag }}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign max = section.settings.max_products | default: 8 -%}
{%- assign products_in_collection = collection.products | default: empty -%}

<section
  class="kracht-pgrid kracht-section--soft"
  style="
    --kpg-bg: {{ section.settings.background_color }};
    --kpg-fg: {{ section.settings.text_color }};
    --kpg-pad-y: {{ section.settings.padding_y }}px;
    --kpg-cols: {{ section.settings.columns_desktop }};
    --kpg-cols-tablet: {{ section.settings.columns_tablet }};
  "
>
  <div class="kracht-pgrid__inner kracht-container">
    <div class="kracht-section__head">
      <div class="kracht-section__head-text">
        {%- if section.settings.heading != blank -%}
          <h2 class="kracht-pgrid__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="kracht-pgrid__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: collection.url | default: '#' }}" class="kracht-section__more">
          {{ section.settings.link_label }} <span aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>

    <div class="kracht-pgrid__grid">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in products_in_collection limit: max -%}
          {%- render 'kracht-product-card', product: product -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..max) -%}
          {%- render 'kracht-product-card', product: blank, index: i -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Product Grid",
  "tag": "section",
  "class": "kracht-pgrid-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Populaire producten"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Alle producten"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f4f4f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Kracht — Product Grid"
    }
  ]
}
{% endschema %}
