{{ 'kracht-product-detail.css' | asset_url | stylesheet_tag }}

{%- assign product = product -%}

<section
  class="kracht-pdetail"
  style="
    --kpd-bg: {{ section.settings.background_color }};
    --kpd-fg: {{ section.settings.text_color }};
    --kpd-pad-y: {{ section.settings.padding_y | times: 0.75 | round }}px;
  "
>
  <div class="kracht-pdetail__inner kracht-container">

    {%- if section.settings.show_breadcrumbs -%}
      <nav class="kracht-pdetail__crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="kracht-pdetail__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
        <a href="{{ routes.collections_url }}">Collecties</a>
        {%- if product.collections.first -%}
          <span class="kracht-pdetail__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
          <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
        {%- endif -%}
        {%- if product.type != blank -%}
          <span class="kracht-pdetail__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
          <span>{{ product.type }}</span>
        {%- endif -%}
        {%- if product != blank -%}
          <span class="kracht-pdetail__crumb-sep" aria-hidden="true">{% render 'kracht-plus' %}</span>
          <span class="is-current">{{ product.title }}</span>
        {%- endif -%}
      </nav>
    {%- endif -%}

    <div class="kracht-pdetail__layout">
      <!-- Gallery -->
      <div class="kracht-pdetail__gallery">
        {%- if product != blank and product.images.size > 0 -%}
          <div class="kracht-pdetail__thumbs">
            {%- for image in product.images limit: 6 -%}
              <button class="kracht-pdetail__thumb {% if forloop.first %}is-active{% endif %}" data-idx="{{ forloop.index0 }}" type="button" aria-label="Afbeelding {{ forloop.index }}">
                <img src="{{ image | image_url: width: 120 }}" alt="" loading="lazy">
              </button>
            {%- endfor -%}
          </div>
          <div class="kracht-pdetail__main-img">
            {%- if section.settings.show_new_tag -%}
              <span class="kracht-tag kracht-tag--with-plus kracht-pdetail__corner-tag">Nieuw</span>
            {%- endif -%}
            {%- for image in product.images limit: 6 -%}
              <img
                src="{{ image | image_url: width: 1000 }}"
                alt="{{ image.alt | default: product.title }}"
                class="kracht-pdetail__main-img-el {% if forloop.first %}is-active{% endif %}"
                data-idx="{{ forloop.index0 }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {%- endfor -%}
            <button class="kracht-pdetail__zoom" type="button" aria-label="Vergroten">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5M11 8v6M8 11h6"/></svg>
            </button>
          </div>
        {%- else -%}
          <div class="kracht-pdetail__thumbs">
            {%- for i in (1..5) -%}
              <button class="kracht-pdetail__thumb {% if forloop.first %}is-active{% endif %}" type="button" aria-label="Voorbeeldafbeelding {{ forloop.index }}">
                <span class="kracht-pdetail__ph"></span>
              </button>
            {%- endfor -%}
          </div>
          <div class="kracht-pdetail__main-img">
            {%- if section.settings.show_new_tag -%}
              <span class="kracht-tag kracht-tag--with-plus kracht-pdetail__corner-tag">Nieuw</span>
            {%- endif -%}
            <div class="kracht-pdetail__main-img-el is-active kracht-pdetail__ph"></div>
          </div>
        {%- endif -%}
      </div>

      <!-- Buy box -->
      <div class="kracht-pdetail__info">
        {%- if section.settings.eyebrow != blank -%}
          <span class="kracht-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        {%- if product != blank -%}
          {%- assign brand_name = section.settings.brand_prefix | default: 'Kracht+' -%}
          <h1 class="kracht-pdetail__title">
            {{ brand_name }}<br>
            <strong>
              {%- assign title_split = product.title | split: ' — ' -%}
              {%- if title_split.size > 1 -%}
                {{ title_split[0] }} <span class="kracht-accent">— {{ title_split[1] }}</span>
              {%- else -%}
                {{ product.title }}
              {%- endif -%}
            </strong>
          </h1>

          <div class="kracht-pdetail__price-row">
            <span class="kracht-pdetail__price">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
              <s class="kracht-pdetail__compare">{{ product.compare_at_price | money }}</s>
              {%- assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
              <span class="kracht-tag kracht-tag--yellow">-{{ discount }}%</span>
            {%- endif -%}
            <span class="kracht-pdetail__tax">incl. btw</span>
          </div>

          {%- if product.description != blank -%}
            <div class="kracht-pdetail__desc">{{ product.description }}</div>
          {%- endif -%}

          {%- form 'product', product, class: 'kracht-pdetail__form' -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

            {%- for option in product.options_with_values -%}
              <div class="kracht-pdetail__option">
                <span class="kracht-pdetail__option-label">
                  {{ option.name | upcase }}
                  <strong>{{ option.selected_value }}</strong>
                </span>
                <div class="kracht-pdetail__swatches">
                  {%- for value in option.values -%}
                    {%- assign vname = value | downcase -%}
                    {%- if option.name == 'Color' or option.name == 'Kleur' -%}
                      <button type="button" class="kracht-pdetail__sw-color {% if option.selected_value == value %}is-active{% endif %}" style="background: {{ vname | replace: 'zwart','#000' | replace: 'wit','#fff' | replace: 'blauw','#009de1' | replace: 'grijs','#999' | replace: 'geel','#FAB725' }};" aria-label="{{ value }}"></button>
                    {%- else -%}
                      <button type="button" class="kracht-pdetail__sw-size {% if option.selected_value == value %}is-active{% endif %}">{{ value }}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                {%- if option.name != 'Color' and option.name != 'Kleur' and section.settings.show_size_guide -%}
                  <a href="#size-guide" class="kracht-pdetail__sg">Maatgids <span aria-hidden="true">→</span></a>
                {%- endif -%}
              </div>
            {%- endfor -%}

            <div class="kracht-pdetail__add-row">
              <div class="kracht-pdetail__qty">
                <button type="button" class="kracht-pdetail__qty-btn" data-q="-" aria-label="Min">−</button>
                <input type="number" name="quantity" value="1" min="1" class="kracht-pdetail__qty-input">
                <button type="button" class="kracht-pdetail__qty-btn" data-q="+" aria-label="Plus">+</button>
              </div>
              <button type="submit" class="kracht-btn kracht-btn--primary kracht-pdetail__add">
                Toevoegen aan winkelwagen <span class="kracht-btn__arrow">→</span>
              </button>
              <button type="button" class="kracht-pdetail__wish" aria-label="Wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-4.5-9.4-9C.7 8.4 2.7 4 6.5 4c2 0 3.6 1.1 4.5 2.6h2c.9-1.5 2.5-2.6 4.5-2.6 3.8 0 5.8 4.4 3.9 8-2.4 4.5-9.4 9-9.4 9z"/></svg>
              </button>
            </div>
          {%- endform -%}

        {%- else -%}
          <h1 class="kracht-pdetail__title">
            Kracht+<br><strong>Team Tee <span class="kracht-accent">— Zwart</span></strong>
          </h1>
          <div class="kracht-pdetail__price-row">
            <span class="kracht-pdetail__price">€39,95</span>
            <s class="kracht-pdetail__compare">€49,95</s>
            <span class="kracht-tag kracht-tag--yellow">-20%</span>
            <span class="kracht-pdetail__tax">incl. btw</span>
          </div>
          <p class="kracht-pdetail__desc">De <strong>Team Tee</strong> is dé essential voor elk Kracht teamlid. Gemaakt van premium 100% katoen, ademend en duurzaam — dag in, dag uit. Draag je <strong>Kracht</strong> met trots, in stijl en comfort.</p>
        {%- endif -%}

        <ul class="kracht-pdetail__usps">
          {%- for block in section.blocks -%}
            {%- if block.type == 'usp' -%}
              <li {{ block.shopify_attributes }}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span><strong>{{ block.settings.title }}</strong> {{ block.settings.subtitle }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;

    // Image switcher
    const thumbs = root.querySelectorAll('.kracht-pdetail__thumb');
    const mains = root.querySelectorAll('.kracht-pdetail__main-img-el');
    thumbs.forEach((t, i) => {
      t.addEventListener('click', () => {
        thumbs.forEach(x => x.classList.remove('is-active'));
        mains.forEach(x => x.classList.remove('is-active'));
        t.classList.add('is-active');
        if (mains[i]) mains[i].classList.add('is-active');
      });
    });

    // Quantity
    const qInput = root.querySelector('.kracht-pdetail__qty-input');
    root.querySelectorAll('.kracht-pdetail__qty-btn').forEach(b => {
      b.addEventListener('click', () => {
        if (!qInput) return;
        const val = parseInt(qInput.value || '1', 10);
        qInput.value = b.dataset.q === '+' ? val + 1 : Math.max(1, val - 1);
      });
    });

    // Variant swatches
    root.querySelectorAll('.kracht-pdetail__sw-color, .kracht-pdetail__sw-size').forEach(b => {
      b.addEventListener('click', () => {
        const grp = b.parentElement;
        grp.querySelectorAll('button').forEach(x => x.classList.remove('is-active'));
        b.classList.add('is-active');
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Kracht — Product Detail",
  "tag": "section",
  "class": "kracht-pdetail-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "T-shirts · Essentials"
    },
    {
      "type": "text",
      "id": "brand_prefix",
      "label": "Brand prefix above title",
      "default": "Kracht+"
    },
    {
      "type": "checkbox",
      "id": "show_new_tag",
      "label": "Show 'Nieuw' tag on image",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_size_guide",
      "label": "Show 'Maatgids →' link",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "Trust line (USP)",
      "settings": [
        { "type": "text", "id": "title", "label": "Title (bold)", "default": "Gratis verzending" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "vanaf €50" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Product Detail",
      "blocks": [
        { "type": "usp", "settings": { "title": "Gratis verzending",  "subtitle": "vanaf €50" } },
        { "type": "usp", "settings": { "title": "Op voorraad",       "subtitle": "— vandaag besteld" } },
        { "type": "usp", "settings": { "title": "30 dagen retour",   "subtitle": "recht" } },
        { "type": "usp", "settings": { "title": "Premium kwaliteit", "subtitle": "gegarandeerd" } }
      ]
    }
  ]
}
{% endschema %}
