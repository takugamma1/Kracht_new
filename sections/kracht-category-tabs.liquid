{{ 'kracht-category-tabs.css' | asset_url | stylesheet_tag }}

<section
  class="kracht-cattabs"
  style="
    --kct-bg: {{ section.settings.background_color }};
    --kct-fg: {{ section.settings.text_color }};
    --kct-active-bg: {{ section.settings.active_color }};
    --kct-active-fg: {{ section.settings.active_text_color }};
    --kct-pad-y: {{ section.settings.padding_y }}px;
  "
>
  <div class="kracht-cattabs__inner kracht-container">
    <div class="kracht-cattabs__scroll">
      {%- for block in section.blocks -%}
        {%- assign tab_url = block.settings.link | default: '#' -%}
        {%- assign is_active = false -%}
        {%- if collection.url == tab_url -%}{%- assign is_active = true -%}{%- endif -%}
        {%- if forloop.first and section.settings.first_active and collection.url == blank -%}{%- assign is_active = true -%}{%- endif -%}

        <a class="kracht-cattabs__item {% if is_active %}is-active{% endif %}" href="{{ tab_url }}" {{ block.shopify_attributes }}>
          <span class="kracht-cattabs__icon">
            {%- case block.settings.icon -%}
              {%- when 'all' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
              {%- when 'tshirt' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M3 7l5-3 4 2 4-2 5 3-2 4-3-1v10H8V10L5 11 3 7z"/></svg>
              {%- when 'polo' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M3 7l5-3 4 3 4-3 5 3-2 4-3-1v10H8V10L5 11 3 7z"/><path d="M10 5l2 2 2-2"/></svg>
              {%- when 'hoodie' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M5 9c0-3 3-5 7-5s7 2 7 5l3 4-3 1v7H8v-7l-3-1 3-4z"/></svg>
              {%- when 'jacket' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M3 7l5-3v17h8V4l5 3-2 5-3-1v8H8v-8L5 12 3 7z"/></svg>
              {%- when 'workwear' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M5 8c1-3 3-4 7-4s6 1 7 4l1 4-3 1v8H7v-8l-3-1 1-4z"/><path d="M9 6l3 3 3-3"/></svg>
              {%- when 'pants' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M5 3h14l-1 8-2 10h-3l-1-7-1 7H8L6 11 5 3z"/></svg>
              {%- when 'sport' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3.5 9c4 1 13 1 17 0M3.5 15c4-1 13-1 17 0M9 3.5c-1 4-1 13 0 17M15 3.5c1 4 1 13 0 17"/></svg>
              {%- when 'cap' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M3 16h18l-2-3c-2-3-4-5-7-5s-5 2-7 5l-2 3z"/><circle cx="12" cy="11" r="0.8" fill="currentColor"/></svg>
              {%- when 'helmet' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M3 17c0-5 4-9 9-9s9 4 9 9H3z"/><path d="M3 17h18v2H3z"/><path d="M11 8V5h2v3"/></svg>
              {%- when 'bag' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"><path d="M5 8h14l-1 12H6L5 8z"/><path d="M9 8V5a3 3 0 0 1 6 0v3"/></svg>
              {%- when 'star' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.1 6.3 6.9 1-5 4.9 1.2 6.9L12 17.8 5.8 21l1.2-6.9-5-4.9 6.9-1L12 2z"/></svg>
            {%- endcase -%}
          </span>
          <span class="kracht-cattabs__label">{{ block.settings.label }}</span>
          {%- if block.settings.count != blank -%}
            <span class="kracht-cattabs__count">{{ block.settings.count }} items</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kracht — Category Tabs",
  "tag": "section",
  "class": "kracht-cattabs-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "first_active",
      "label": "Mark first tab as active by default",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active background",
      "default": "#009de1"
    },
    {
      "type": "color",
      "id": "active_text_color",
      "label": "Active text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_y",
      "label": "Vertical padding",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "all", "label": "All / Grid" },
            { "value": "tshirt", "label": "T-shirt" },
            { "value": "polo", "label": "Polo" },
            { "value": "hoodie", "label": "Hoodie" },
            { "value": "jacket", "label": "Jacket" },
            { "value": "workwear", "label": "Workwear" },
            { "value": "pants", "label": "Pants" },
            { "value": "sport", "label": "Sport" },
            { "value": "cap", "label": "Cap" },
            { "value": "helmet", "label": "Helmet" },
            { "value": "bag", "label": "Bag" },
            { "value": "star", "label": "Star" }
          ],
          "default": "tshirt"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "T-shirts" },
        { "type": "text", "id": "count", "label": "Item count", "default": "14" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kracht — Category Tabs",
      "blocks": [
        { "type": "tab", "settings": { "icon": "all",      "label": "Alle kleding", "count": "48" } },
        { "type": "tab", "settings": { "icon": "tshirt",   "label": "T-shirts",     "count": "14" } },
        { "type": "tab", "settings": { "icon": "polo",     "label": "Polo's",       "count": "8"  } },
        { "type": "tab", "settings": { "icon": "hoodie",   "label": "Hoodies",      "count": "6"  } },
        { "type": "tab", "settings": { "icon": "jacket",   "label": "Jacks",        "count": "5"  } },
        { "type": "tab", "settings": { "icon": "workwear", "label": "Werkkleding",  "count": "9"  } },
        { "type": "tab", "settings": { "icon": "pants",    "label": "Broeken",      "count": "4"  } },
        { "type": "tab", "settings": { "icon": "sport",    "label": "Sport",        "count": "7"  } },
        { "type": "tab", "settings": { "icon": "cap",      "label": "Petten",       "count": "3"  } }
      ]
    }
  ]
}
{% endschema %}
